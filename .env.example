# Variables de entorno del proyecto.
# Copia este archivo a .env.local y completa los valores reales.

# Credenciales de Google Calendar, usadas por las funciones serverless en /api
# (api/availability.ts y api/book.ts) para leer tu disponibilidad real y crear
# los eventos cuando alguien agenda una llamada.
#
# Cómo obtenerlas: sigue las instrucciones del README ("Conectar Google
# Calendar"). Resumen rápido:
#   1. Crea un proyecto en Google Cloud Console y activa la Calendar API.
#   2. Crea credenciales OAuth 2.0 de tipo "Web application" y agrega
#      http://localhost:3939/oauth2callback como Authorized redirect URI.
#   3. Copia el Client ID y Client Secret aquí abajo.
#   4. Corre `npm run get-google-token` y autoriza tu cuenta en el navegador.
#   5. El script te imprime el GOOGLE_REFRESH_TOKEN — pégalo aquí.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ID del calendario donde se crean los eventos nuevos cuando alguien agenda.
# "primary" es tu calendario principal de Gmail.
GOOGLE_CALENDAR_ID=primary

# Lista de calendarios (separados por coma) que cuentan como "ocupado" al
# calcular tu disponibilidad. Útil si tienes reuniones repartidas en varios
# calendarios (ej. uno de un programa de incubación) y no quieres que se
# muestren como libres. Si no la defines, solo se usa GOOGLE_CALENDAR_ID.
# Encuentra los IDs de tus calendarios en Configuración de Google Calendar →
# selecciona el calendario → "Integrar calendario" → "ID de calendario".
GOOGLE_BUSY_CALENDAR_IDS=primary

# Correo donde quieres recibir aviso de cada reserva. Se agrega como invitado
# adicional en el evento (junto al visitante), así que te llega la misma
# invitación de Google Calendar (con el link de Meet). Importante: debe ser
# una cuenta de Google DISTINTA a la del calendario que conectaste arriba —
# si usas la misma cuenta, Google reconoce que eres tú (la organizadora) y no
# manda el correo.
NOTIFY_EMAIL=dommies.dev@gmail.com
